{
  "name": "health-tracker",
  "version": "1.0.0",
  "private": true,
  "description": "Health & Kcal tracking app (React + Express + PostgreSQL)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "npm run dev -w @health-tracker/api",
    "dev:web": "npm run dev -w @health-tracker/web",
    "build": "npm run build -w @health-tracker/shared && npm run build -w @health-tracker/api && npm run build -w @health-tracker/web",
    "start:api": "npm run start -w @health-tracker/api",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "concurrently": "^9.1.2",
    "eslint": "^10.7.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "typescript-eslint": "^8.64.0"
  },
  "engines": {
    "node": ">=20"
  }
}
